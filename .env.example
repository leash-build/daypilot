# ============================================================================
# .env.example — declare the env keys YOUR application code reads at runtime.
# Leash injects values from your dashboard secrets when running `leash dev`
# and on the deployed Cloud Run revision.
#
# Rule of thumb:
#   - Leash-managed vars (LEASH_*, SUPABASE_*) → auto-injected, don't declare
#   - Bound-DB DATABASE_URL → auto-injected when you run `leash db create`
#   - Your own keys (API tokens, BYO DB connection strings) → declare here,
#     set value in dashboard
# ============================================================================

# Required. Anthropic API key for the day-plan generator.
# Set the value in dashboard secrets at:
#   https://leash.build/dashboard/apps/<id>/secrets
ANTHROPIC_API_KEY=


# ----------------------------------------------------------------------------
# BYO database (optional)
# ----------------------------------------------------------------------------
# By default, daypilot uses the Leash-bound database — `leash db create`
# provisions it and DATABASE_URL is auto-injected. Nothing to declare here
# in that case.
#
# If you'd rather use your own Postgres (Supabase, RDS, Neon, etc.), skip
# `leash db create` and uncomment the line below. Set the connection string
# in your dashboard secrets and Leash will inject it at runtime, just like
# any other declared key.
#
# DATABASE_URL=
